{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Edge Analytics Main",
      "type": "python",
      "request": "launch",
      "module": "src",
      "args": ["--scenario", "healthy"],
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "MQTT_BROKER": "localhost",
        "LOGLEVEL": "DEBUG"
      }
    },
    {
      "name": "Python: Pytest",
      "type": "python",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/", "-v", "--tb=short"],
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Python: Pytest (Current File)",
      "type": "python",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-v"],
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}