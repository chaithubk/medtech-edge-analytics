{
  "name": "Edge Analytics (Python 3.10 + TensorFlow Lite)",
  "image": "python:3.10-bookworm",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "ms-python.flake8",
        "ms-python.isort",
        "ms-python.mypy-type-checker",
        "ms-python.debugpy",
        "eamodio.gitlens",
        "github.copilot",
        "github.copilot-chat"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests"],
        "[python]": {
          "editor.formatOnSave": true,
          "editor.defaultFormatter": "ms-python.black-formatter",
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
          },
          "editor.rulers": [100]
        },
        "black-formatter.args": ["--line-length", "100"],
        "isort.args": ["--profile", "black", "--line-length", "100"],
        "flake8.args": ["--max-line-length", "100"],
        "mypy-type-checker.args": ["--ignore-missing-imports"]
      }
    }
  },
  "postCreateCommand": "pip install --upgrade pip && pip install -r requirements-dev.txt",
  "forwardPorts": [1883],
  "portsAttributes": {
    "1883": {
      "label": "MQTT Broker",
      "onAutoForward": "notify"
    }
  },
  "remoteUser": "root",
  "remoteEnv": {
    "PYTHONUNBUFFERED": "1",
    "MQTT_BROKER": "localhost",
    "MQTT_PORT": "1883",
    "LOGLEVEL": "INFO"
  }
}